{
  "name": "bluestack-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "// --- 1. MANTENIMIENTO ---": "",
    "clean": "rm -rf allure-results allure-report blob-report allure-history.jsonl logs",
    "clean:safe": "rm -rf allure-results",
    "// --- 2. INFRAESTRUCTURA (DOCKER) ---": "",
    "// UNA VEZ al iniciar tu día o sesión de pruebas grid": "",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:restart": "npm run infra:down && npm run infra:up",
    "// --- 3. EJECUCIÓN (CORE) ---": "",
    "// Estos scripts solo corren tests. Asumen que el entorno (Local o Docker) ya está listo.": "",
    "// DEV: Navegador visible. <pattern> puede ser nombre de carpeta (video) o de archivo (NewPost).": "",
    "exec:dev": "cross-env NODE_OPTIONS='--experimental-vm-modules' USE_GRID=false IS_HEADLESS=false jest",
    "// GRID: Headless contra Docker. Mismo filtrado por <pattern>.": "",
    "exec:grid": "cross-env NODE_OPTIONS='--experimental-vm-modules' USE_GRID=true IS_HEADLESS=true jest",
    "// --- 4. WORKFLOWS ---": "",
    "// Limpia y corre desarrollo local (sin Docker)": "",
    "test:dev": "npm run clean:safe && npm run exec:dev --",
    "// Alias: Igual pero para modo DEV": "",
    "test:dev:show": "npm run test:dev || true && npm run report:show",
    "// Limpia y corre en un Grid con Docker": "",
    "test:grid": "npm run exec:grid --",
    "test:grid:show": "npm run test:grid || true && npm run report:show",
    "// CI: Flujo completo. Limpia -> Levanta Docker -> Corre -> Baja Docker. (GitHub Actions)": "",
    "test:ci": "npm run clean:safe && npm run infra:up && npm run exec:grid -- --ci --runInBand --colors --forceExit && npm run infra:down",
    "// --- 4b. MULTI-ENTORNO ---": "",
    "// Conveniencia: TARGET_ENV inyectado. Pasar <pattern> igual que en test:dev / test:grid.": "",
    "test:dev:master": "cross-env TARGET_ENV=master npm run test:dev --",
    "test:grid:master": "cross-env TARGET_ENV=master npm run test:grid --",
    "test:dev:cliente": "cross-env TARGET_ENV=cliente npm run test:dev --",
    "test:grid:cliente": "cross-env TARGET_ENV=cliente npm run test:grid --",
    "// --- 5. REPORTES ---": "",
    "report:clean": "rm -rf allure-report",
    "report:gen": "npm run report:clean && npx allure generate allure-results -o allure-report --config allure.config.json",
    "report:open": "npx allure open allure-report",
    "report:show": "npm run report:gen && npm run report:open"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "selenium-webdriver": "^4.38.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.39",
    "@types/selenium-webdriver": "^4.1.22",
    "@types/ws": "^8.5.10",
    "allure": "^3.3.1",
    "allure-jest": "^3.4.5",
    "allure-js-commons": "^3.4.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.x.x"
  }
}
