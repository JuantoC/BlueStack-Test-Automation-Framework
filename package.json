{
  "name": "bluestack-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "// --- 🧹 MANTENIMIENTO ---": "",
    "clean": "rm -rf logs/* allure-results/* allure-report/*",

    "// --- 🐳 INFRAESTRUCTURA (DOCKER) ---": "",
    "infra:up": "docker compose up -d && sleep 5",
    "infra:down": "docker compose down",
    "infra:restart": "npm run infra:down && npm run infra:up",

    "// --- 🧪 EJECUCIÓN DE TESTS ---": "",
    "// 1. MODO DESARROLLO: Local, navegador visible, sin Docker, uno por uno (serial)": "",
    "test:dev": "cross-env NODE_OPTIONS='--experimental-vm-modules' USE_GRID=false IS_HEADLESS=false jest --runInBand",

    "// 2. MODO GRID: Local, pero usando el Grid de Docker, headless, paralelo": "",
    "test:grid": "npm run clean && npm run infra:up && cross-env NODE_OPTIONS='--experimental-vm-modules' USE_GRID=true IS_HEADLESS=true jest || (npm run infra:down && exit 1)",

    "// 3. MODO CI: Igual al Grid, pero sin limpieza automática posterior (el CI mata el contenedor)": "",
  "test:ci": "npm run clean && npm run infra:up && cross-env NODE_OPTIONS='--experimental-vm-modules' USE_GRID=true IS_HEADLESS=true jest --ci --runInBand --colors",

    "// --- 📊 REPORTES ---": "",
    "report:gen": "npx allure generate allure-results -o allure-report",
    "report:open": "npx serve allure-report -p 9999",
    "report:show": "npm run report:gen && npm run report:open"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "selenium-webdriver": "^4.38.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.x.x",
    "@types/selenium-webdriver": "^4.1.22",
    "@types/ws": "^8.5.10",
    "allure-jest": "^3.4.5",
    "allure-js-commons": "^3.4.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.x.x"
  }
}