{
  "name": "bluestack-automation-framework",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf logs/* allure-results/* allure-report/*",
    "grid:up": "docker compose up -d --scale chrome-node=${MAX_INSTANCES:-1}",
    "grid:down": "docker compose down",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:pick": "cross-env NODE_OPTIONS='--experimental-vm-modules' TEST_FILE=$npm_config_file jest",
    "test:stress": "npm run clean && npm run grid:up && npm run test:ci",
    "test:ci": "npm run test || true && npm run grid:down && npm run report:gen",
    "report:gen": "npx allure generate allure-results --clean -o allure-report",
    "report:open": "npx serve allure-report -p 9999"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "selenium-webdriver": "^4.38.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.x.x",
    "@types/selenium-webdriver": "^4.1.22",
    "@types/ws": "^8.5.10",
    "allure-jest": "^3.4.5",
    "allure-js-commons": "^3.4.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.x.x"
  }
}
