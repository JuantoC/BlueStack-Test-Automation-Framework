{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "rootDir": ".",
    "outDir": "./dist",
    "lib": [
      "es2022"
    ],
    "types": [
      "node",
      "selenium-webdriver",
      "jest"
    ],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "isolatedModules": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}