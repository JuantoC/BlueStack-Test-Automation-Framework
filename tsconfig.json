{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext", // Fundamental para ESM y Jest
    "esModuleInterop": true,
    "rootDir": ".", // Ahora permite archivos en src/ y tests/
    "outDir": "./dist",
    "lib": [
      "es2022"
    ],
    "types": [
      "node",
      "selenium-webdriver",
      "jest" // Agregado para quitar el error de 'describe'
    ],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "isolatedModules": true
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}